    },
    {
      "id": "step-5-web-app",
      "title": "The Next.js Web Shell",
      "description": "The web app is intentionally thin. Route shells are tiny — each one simply imports its corresponding page from the shared views package. The platform bridge is the only place that touches Next.js APIs, browser globals, and environment variables, and it wires up the API client, stores, navigation, and storage. Each future client provides its own bridge.",
      "estimatedTime": 120,
      "focusDirectory": "apps/web",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "platform-bridge",
          "name": "Platform Bridge",
          "color": "#ef4444",
          "items": [
            { "path": "apps/web/platform", "type": "directory" }
          ],
          "opacity": 0.75,
          "renderStrategy": "fill"
        },
        {
          "id": "route-shells",
          "name": "Route Shells",
          "color": "#3b82f6",
          "items": [
            { "path": "apps/web/app", "type": "directory" }
          ],
          "opacity": 0.6,
          "renderStrategy": "border",
          "borderWidth": 3
        },
        {
          "id": "web-features",
          "name": "Web-Only Features",
          "color": "#f59e0b",
          "items": [
            { "path": "apps/web/features", "type": "directory" }
          ],
          "opacity": 0.6,
          "renderStrategy": "border",
          "borderWidth": 2
        }
      ],
      "interactiveActions": [
        {
          "type": "hover-directory",
          "description": "Hover the platform bridge — the only place that talks to Next.js or the browser",
          "target": "apps/web/platform"
        }
      ]
    },
    {
      "id": "step-6-go-backend",
      "title": "Go Backend — Entry Points & Handlers",
      "description": "The Go backend has three entry points: the HTTP API, the command-line tool, and the migration runner. Handlers are grouped one per domain — issues, comments, agents, auth, and the daemon — and each handler wires together database access, the real-time hub, and the task service. A central router stitches everything together.",
      "estimatedTime": 120,
      "focusDirectory": "server",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "entry-points",
          "name": "Entry Points",
          "color": "#8b5cf6",
          "items": [
            { "path": "server/cmd/server", "type": "directory" },
            { "path": "server/cmd/multica", "type": "directory" },
            { "path": "server/cmd/migrate", "type": "directory" }
          ],
          "opacity": 0.75,
          "renderStrategy": "fill"
        },
        {
          "id": "http-handlers",
          "name": "HTTP Handlers",
          "color": "#3b82f6",
          "items": [
            { "path": "server/internal/handler", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "fill"
        },
        {
          "id": "auth-middleware",
          "name": "Auth & Middleware",
          "color": "#ef4444",
          "items": [
            { "path": "server/internal/auth", "type": "directory" },
