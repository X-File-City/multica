          ],
          "opacity": 0.75,
          "renderStrategy": "fill"
        }
      ]
    },
    {
      "id": "step-9-tests-and-tooling",
      "title": "Testing, E2E & Build Tooling",
      "description": "End-to-end coverage runs through Playwright, the TypeScript side uses Vitest for unit tests, and Go uses its standard test runner. Turborepo orchestrates the frontend pipeline, and a single make target runs the full verification loop — typecheck, unit tests, Go tests, and end-to-end — so any change can be validated with one command.",
      "estimatedTime": 90,
      "focusDirectory": "",
