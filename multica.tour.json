    {
      "id": "step-8-database-layer",
      "title": "Database — Queries, Migrations & pgvector",
      "description": "Multica runs on PostgreSQL with the pgvector extension. Hand-written SQL queries are turned into type-safe Go code by a code generator, and schema changes flow through versioned migrations. Every query filters by workspace, which is how multi-tenancy is enforced across the entire system.",
      "estimatedTime": 90,
      "focusDirectory": "server",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "sqlc-queries",
