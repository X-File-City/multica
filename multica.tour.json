{
  "id": "multica-codebase-tour",
  "title": "Multica Codebase Tour",
  "description": "A guided walkthrough of Multica — an AI-native task management platform with a Go backend, a Next.js frontend, and shared headless packages designed for multi-platform reuse.",
  "version": "1.0.0",
  "audience": "New Developers & AI Assistants",
  "prerequisites": [
    "Familiarity with Go and TypeScript",
    "Basic understanding of monorepos and React"
  ],
  "steps": [
    {
      "id": "step-1-welcome",
      "title": "Welcome to Multica",
      "description": "Multica is an AI-native task management platform — like Linear, but with AI agents as first-class citizens. Agents can be assigned issues, create them, comment, and change status. The codebase is split into three highlighted areas: a Go backend, a Next.js web app, and shared TypeScript packages built for multi-platform reuse.",
      "estimatedTime": 60,
      "focusDirectory": "",
      "colorMode": "fileTypes",
      "resources": [
        {
          "title": "Project README",
          "url": "README.md",
          "type": "documentation"
        },
        {
          "title": "CLAUDE.md — AI agent guide",
          "url": "CLAUDE.md",
          "type": "documentation"
        }
      ]
    },
    {
      "id": "step-2-monorepo-packages",
      "title": "Shared Package Architecture",
      "description": "The frontend is a monorepo with three shared packages plus a base config. Dependencies flow in one direction: views builds on core and ui, while core and ui stay independent of each other. No package leaks framework-specific imports, which is what keeps the business logic reusable across web, desktop, and mobile clients.",
      "estimatedTime": 90,
      "focusDirectory": "packages",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "package-core",
          "name": "@multica/core (headless logic)",
          "color": "#3b82f6",
          "items": [
            { "path": "packages/core", "type": "directory" }
          ],
          "opacity": 0.6,
          "renderStrategy": "border",
          "borderWidth": 3
        },
        {
          "id": "package-ui",
          "name": "@multica/ui (atomic components)",
          "color": "#10b981",
          "items": [
            { "path": "packages/ui", "type": "directory" }
          ],
          "opacity": 0.6,
          "renderStrategy": "border",
          "borderWidth": 3
        },
        {
          "id": "package-views",
          "name": "@multica/views (business pages)",
          "color": "#f59e0b",
          "items": [
            { "path": "packages/views", "type": "directory" }
          ],
          "opacity": 0.6,
          "renderStrategy": "border",
          "borderWidth": 3
        },
        {
          "id": "package-tsconfig",
          "name": "@multica/tsconfig",
          "color": "#6b7280",
          "items": [
            { "path": "packages/tsconfig", "type": "directory" }
          ],
          "opacity": 0.5,
          "renderStrategy": "border",
          "borderWidth": 2
        }
      ]
    },
    {
      "id": "step-3-core-package",
      "title": "@multica/core — Headless Business Logic",
      "description": "The core package holds all domain types, the API client, query and mutation definitions, client-side stores, and real-time sync. It has no direct ties to the DOM, browser storage, or environment variables — anything platform-specific is injected at startup. This is what lets the same logic run on web, desktop, and mobile.",
      "estimatedTime": 120,
      "focusDirectory": "packages/core",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "core-domains",
          "name": "Domain Modules",
          "color": "#3b82f6",
          "items": [
            { "path": "packages/core/issues", "type": "directory" },
            { "path": "packages/core/inbox", "type": "directory" },
            { "path": "packages/core/runtimes", "type": "directory" },
            { "path": "packages/core/projects", "type": "directory" },
            { "path": "packages/core/workspace", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "fill"
        },
        {
          "id": "core-infrastructure",
          "name": "Infrastructure",
          "color": "#a855f7",
          "items": [
            { "path": "packages/core/api", "type": "directory" },
            { "path": "packages/core/auth", "type": "directory" },
            { "path": "packages/core/realtime", "type": "directory" },
            { "path": "packages/core/types", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "fill"
        }
      ],
      "interactiveActions": [
        {
          "type": "explore",
          "description": "Open the issues domain to see the queries, mutations, and store pattern repeated across every domain"
        }
      ]
    },
    {
      "id": "step-4-ui-and-views",
      "title": "@multica/ui & @multica/views",
      "description": "The ui package holds shadcn primitives and pure-props common components — no business logic. The views package builds on top of both ui and core to deliver complete pages: the issue board, editor, modals, runtimes, and skills. Views routes through a navigation adapter so it can run inside any framework, not just Next.js.",
      "estimatedTime": 90,
      "focusDirectory": "packages",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "ui-primitives",
          "name": "shadcn primitives",
          "color": "#10b981",
          "items": [
            { "path": "packages/ui/components", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "fill"
        },
        {
          "id": "views-domain-pages",
          "name": "Domain Pages",
          "color": "#f59e0b",
          "items": [
            { "path": "packages/views/issues", "type": "directory" },
            { "path": "packages/views/editor", "type": "directory" },
            { "path": "packages/views/modals", "type": "directory" },
            { "path": "packages/views/runtimes", "type": "directory" },
            { "path": "packages/views/skills", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "fill"
        },
        {
          "id": "navigation-adapter",
