        }
      ]
    },
    {
      "id": "step-7-realtime-and-agents",
      "title": "Real-Time, Task Service & Agent SDK",
      "description": "Three subsystems power the AI-native experience. The real-time hub broadcasts events over WebSockets to keep every client in sync. The task service orchestrates agent work — enqueue, claim, start, then complete or fail — and keeps issue status aligned. The agent SDK provides a unified interface that can spawn either Claude Code or Codex, and the local daemon polls for tasks and routes them to the right backend.",
      "estimatedTime": 150,
      "focusDirectory": "server",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "realtime-hub",
          "name": "WebSocket Hub",
          "color": "#10b981",
          "items": [
            { "path": "server/internal/realtime", "type": "directory" }
          ],
          "opacity": 0.75,
          "renderStrategy": "fill"
        },
