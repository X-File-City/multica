            { "path": "server/internal/events", "type": "directory" }
          ],
          "opacity": 0.75,
          "renderStrategy": "fill"
        },
        {
          "id": "agent-sdk",
          "name": "Agent SDK (Claude / Codex)",
          "color": "#a855f7",
